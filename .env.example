# 复制本文件为你自己的环境变量文件，再按需修改后执行：
#   set -a
#   . ./.env
#   set +a
#   bash install.sh

# 必填：Mihomo 订阅地址
MIHOMO_SUBSCRIPTION_URL='https://example.invalid/subscription'

# 可选：固定 Mihomo controller secret。
# 不填则脚本会自动生成，或复用当前 /etc/mihomo/config.yaml 中已有的 secret。
# MIHOMO_SECRET='replace-with-a-random-secret'

# 可选：指定 Mihomo 版本（默认 latest）
# MIHOMO_VERSION='v1.19.20'

# 可选：直接指定 Mihomo 下载地址
# MIHOMO_DOWNLOAD_URL='https://example.invalid/mihomo-linux-amd64-v1-v1.19.20.gz'

# 可选：指定本地离线包路径
# MIHOMO_DOWNLOAD_FILE='/opt/packages/mihomo-linux-amd64-v1-v1.19.20.gz'

# 可选：下载镜像前缀，多个值可用逗号、分号分隔
# MIHOMO_DOWNLOAD_MIRROR_PREFIXES='https://mirror-1.example.invalid/,https://mirror-2.example.invalid/'

# 可选：离线包自动扫描目录，多个值可用冒号、逗号、分号分隔
# MIHOMO_OFFLINE_SEARCH_DIRS='/data/pkg:/srv/cache/mihomo'

# 可选：手工指定 Mihomo release 资产名
# MIHOMO_ASSET_NAME='mihomo-linux-amd64-v1-v1.19.20.gz'

# 可选：手工指定 Mihomo 安装路径
# MIHOMO_BIN='/usr/local/bin/mihomo'

# 可选：手工指定 Mihomo systemd unit 文件路径
# MIHOMO_SYSTEMD_UNIT='/etc/systemd/system/mihomo.service'
